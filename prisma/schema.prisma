generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  plan         String   @default("FREE")
  planUntil    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  solves   Solve[]
  payments Payment[]
}

model Solve {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  result    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  orderId   String
  cfOrderId String?
  plan      String
  amount    Int
  currency  String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}